{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "composite": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "moyan-mfw-core": ["./packages/core/dist"],
      "moyan-mfw-base/backend": ["./packages/base/src/backend/src/index.ts"],
      "moyan-mfw-base/frontend": ["./packages/base/src/frontend/src/index.ts"],
      "moyan-mfw-base-api": ["./packages/base-api/dist"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "e2e",
    "backend",
    "frontend",
    "business-dict",
    "packages",
    "packages/*/tests",
    "packages/*/__tests__"
  ]
}
