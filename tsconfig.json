{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "removeComments": false,
    "paths": {
      "moyan-mfw-core": ["./packages/core/dist"],
      "moyan-mfw-base-backend": ["./packages/base-backend/dist"],
      "moyan-mfw-base-frontend": ["./packages/base-frontend/dist"],
      "moyan-mfw-base-api": ["./packages/base-api/dist"],
      "moyan-shared-dict": ["./packages/shared-dict/dist/esm"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "e2e",
    "backend",
    "frontend",
    "business-dict",
    "packages",
    "packages/*/tests",
    "packages/*/__tests__"
  ]
}
