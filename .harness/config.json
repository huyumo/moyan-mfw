{
  "$schema": "https://json.schemastore.org/harness-config.json",
  "version": "2.1.0",
  "description": "Harness 核心配置 - 严格模式和钩子参数",

  "enforcement": {
    "strict-mode": false,
    "blockOnFailure": true
  },

  "qualityGate": {
    "requiredChecks": [
      "typecheck",
      "lint",
      "self-review",
      "test-coverage"
    ],
    "coverageThresholds": {
      "lines": 60,
      "functions": 60,
      "branches": 50,
      "statements": 60
    }
  },

  "hookConfig": {
    "agentParticipation": {
      "minWordCount": 100,
      "minFileCount": 1,
      "minSubstantiveLines": 3
    },
    "taskComplexity": {
      "minPendingTasks": 5,
      "minDomains": 2
    },
    "timestamp": {
      "allowedDelayMinutes": 30
    },
    "meetingNotes": {
      "minRequiredFields": 2
    }
  },

  "notifications": {
    "enabled": true,
    "logToFile": true,
    "logDirectory": ".harness/output/logs"
  }
}
