{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "代码审查配置 Schema",
  "description": "定义代码审查配置的格式",
  "type": "object",
  "required": ["security", "performance", "maintainability", "testing", "codeStyle"],
  "properties": {
    "security": {
      "type": "object",
      "properties": {
        "criticalChecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "checks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "maintainability": {
      "type": "object",
      "properties": {
        "checks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "testing": {
      "type": "object",
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "codeStyle": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "vueSpecific": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "templateRules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
