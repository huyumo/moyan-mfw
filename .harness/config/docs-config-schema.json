{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "文档模板配置 Schema",
  "description": "定义文档模板配置的格式",
  "type": "object",
  "required": ["templates"],
  "properties": {
    "templates": {
      "type": "object",
      "properties": {
        "apiDoc": { "type": "string" },
        "designDoc": { "type": "string" },
        "userGuide": { "type": "string" },
        "readme": { "type": "string" },
        "meetingNotes": { "type": "string" },
        "taskReport": { "type": "string" }
      }
    },
    "docLocations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "documentationRules": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
