{
  "$schema": "./review-config-schema.json",
  "description": "代码审查配置 - 请根据实际项目修改此文件",
  "security": {
    "criticalChecks": [
      "无硬编码凭证（密码、API Key、Token）",
      "无 eval()、exec() 等危险函数调用",
      "所有用户输入已验证（类型、长度、格式）",
      "所有输出已编码（防止 XSS）",
      "使用参数化查询/ORM（防止 SQL 注入）",
      "敏感数据加密存储",
      "无__proto__、prototype 污染风险",
      "文件上传有限制（类型、大小）",
      "认证/授权逻辑完整",
      "速率限制已实现"
    ],
    "blockers": [
      "发现明文密码存储",
      "发现 SQL 注入漏洞",
      "发现硬编码凭证"
    ]
  },
  "performance": {
    "checks": [
      "无 N+1 查询问题",
      "适当的数据库索引",
      "缓存策略合理",
      "资源及时释放（连接、文件句柄）",
      "大数据集已分页",
      "避免同步阻塞操作",
      "异步操作有错误处理",
      "循环内无重复计算"
    ],
    "thresholds": {
      "apiResponseTime": "200ms (P95)",
      "dbQueryTime": "50ms (P95)",
      "bundleSize": "500KB"
    }
  },
  "maintainability": {
    "checks": [
      "函数职责单一（SRP）",
      "函数长度合理（< 50 行）",
      "变量/函数命名清晰达意",
      "无魔术数字（使用常量）",
      "错误处理完整",
      "日志记录适当",
      "注释解释为什么而非是什么",
      "无死代码/注释代码",
      "类型定义完整（TypeScript）",
      "公共 API 有文档注释"
    ],
    "metrics": {
      "maxFunctionLength": 50,
      "maxCyclomaticComplexity": 10,
      "minTestCoverage": 0.8
    }
  },
  "testing": {
    "requirements": [
      "单元测试覆盖率 ≥ 80%",
      "关键路径 100% 覆盖",
      "边界条件测试",
      "错误场景测试",
      "集成测试覆盖 API 端点",
      "测试用例独立可运行",
      "测试命名清晰描述场景",
      "Mock 外部依赖"
    ]
  },
  "codeStyle": {
    "rules": [
      "遵循 ESLint 配置",
      "遵循 Prettier 格式化",
      "缩进 2 空格",
      "字符串使用单引号",
      "行尾无分号（JavaScript/TypeScript）",
      "行宽 < 100 字符",
      "import 顺序：内置→第三方→本地",
      "无未使用变量/导入"
    ]
  }
}
