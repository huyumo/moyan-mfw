{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "技术栈配置 Schema",
  "description": "定义项目技术栈配置的格式",
  "type": "object",
  "required": ["techStack"],
  "properties": {
    "techStack": {
      "type": "object",
      "properties": {
        "language": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "runtime": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "description": { "type": "string" },
              "optional": { "type": "boolean" }
            }
          }
        },
        "databases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "description": { "type": "string" },
              "type": { "type": "string", "enum": ["relational", "key-value", "document", "graph"] }
            }
          }
        },
        "testing": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "tooling": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "architectureDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "decision": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["proposed", "accepted", "rejected", "deprecated"] }
        }
      }
    },
    "techDebt": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "addedAt": { "type": "string", "format": "date" }
        }
      }
    },
    "projectStructure": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
