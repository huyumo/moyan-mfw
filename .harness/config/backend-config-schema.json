{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "后端开发规范配置 Schema",
  "description": "定义后端开发规范配置的格式",
  "type": "object",
  "required": ["security", "api", "database", "logging"],
  "properties": {
    "security": {
      "type": "object",
      "properties": {
        "guidelines": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "standards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "standards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "moduleStructure": {
      "type": "object",
      "properties": {
        "standards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
