{
  "name": "moyan-mfw",
  "version": "1.0.0",
  "description": "Moyan backend management framework",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "pnpm --filter moyan-frontend dev",
    "dev:examples": "pnpm --filter moyan-mfw-examples dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter moyan-frontend build",
    "lint": "node tools/run-eslint-targets.cjs",
    "lint:fix": "node tools/run-eslint-targets.cjs --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck:vue": "pnpm --filter moyan-frontend typecheck:vue",
    "typecheck": "pnpm run typecheck:vue",
    "typecheck:scripts": "tsc --project scripts/tsconfig.json",
    "test:comment-rule": "node tools/eslint-plugin-moyan/rules/comment-compliance.test.mjs",
    "validate:links": "tsx scripts/validate-doc-links.spec.ts",
    "validate:docs": "tsx scripts/validate-doc-template.ts",
    "validate:types": "tsx scripts/validate-types.spec.ts",
    "gate:task-archive": "tsx scripts/task-archive-gate.spec.ts",
    "validate:all": "npm run validate:links && npm run validate:types && npm run typecheck:scripts"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "cypress": "^15.12.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.1.9",
    "eslint-plugin-vue": "^10.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.2",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
