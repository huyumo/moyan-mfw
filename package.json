{
  "name": "moyan-mfw",
  "version": "1.1.7",
  "description": "Moyan backend management framework",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "pnpm --filter moyan-mfw-frontend dev",
    "build": "pnpm --filter moyan-mfw-base build && pnpm --filter moyan-mfw-extension-ad build && pnpm --filter moyan-mfw-business-dict build && pnpm --filter moyan-mfw-backend build && pnpm --filter moyan-mfw-frontend build && pnpm run verify:dist",
    "build:frontend": "pnpm --filter moyan-mfw-frontend build",
    "verify:dist": "node scripts/check-dist.mjs && pnpm --filter moyan-mfw-frontend verify-dist",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck:base-shared": "pnpm --filter @internal/base-shared typecheck",
    "typecheck:base-backend": "pnpm --filter @internal/base-backend typecheck",
    "typecheck:base-frontend": "pnpm --filter @internal/base-frontend typecheck",
    "typecheck:ad-shared": "pnpm --filter @internal/ad-shared typecheck",
    "typecheck:ad-backend": "pnpm --filter @internal/ad-backend typecheck",
    "typecheck:ad-frontend": "pnpm --filter @internal/ad-frontend typecheck",
    "typecheck:vue": "pnpm --filter moyan-mfw-frontend typecheck",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "typecheck:backend": "pnpm --filter moyan-mfw-backend typecheck",
    "typecheck": "pnpm run typecheck:base-shared && pnpm run typecheck:ad-shared && pnpm run typecheck:base-backend && pnpm run typecheck:ad-backend && pnpm run typecheck:base-frontend && pnpm run typecheck:ad-frontend && pnpm run typecheck:vue && pnpm run typecheck:backend && pnpm run typecheck:e2e",
    "typecheck:scripts": "tsc --project scripts/tsconfig.json",
    "gen": "plop --plopfile scripts/generators/plopfile.ts",
    "gen:module": "plop --plopfile scripts/generators/plopfile.ts backend-module",
    "gen:page": "plop --plopfile scripts/generators/plopfile.ts frontend-page",
    "gen:component": "plop --plopfile scripts/generators/plopfile.ts frontend-component",
    "validate:skill": "tsx scripts/validate-skill-docs.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "dev:cli": "pnpm --filter moyan-mfw-cli dev",
    "build:cli": "pnpm --filter moyan-mfw-cli build",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major",
    "publish:base": "cd packages/base && npm publish --access public",
    "publish:cli": "cd packages/cli && npm publish --access public",
    "publish:ad": "cd packages/extensions/extension-ad && npm publish --access public",
    "publish:all": "pnpm run publish:base && pnpm run publish:cli && pnpm run publish:ad"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "cypress": "^15.12.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.1.9",
    "eslint-plugin-vue": "^10.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "plop": "^4.0.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.46.2",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
