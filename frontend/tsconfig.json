{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "isolatedModules": true,
    "experimentalDecorators": true,
    "declaration": false,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "moyan-mfw-base/frontend": ["../packages/base/src/frontend/index.ts"],
      "moyan-mfw-base/frontend/*": ["../packages/base/src/frontend/*"],
      "moyan-mfw-base/shared": ["../packages/base/src/shared"],
      "moyan-mfw-extension-ad/frontend": ["../packages/extensions/extension-ad/src/frontend/index.ts"],
      "moyan-mfw-extension-ad/frontend/*": ["../packages/extensions/extension-ad/src/frontend/*"],
      "moyan-mfw-extension-ad/shared": ["../packages/extensions/extension-ad/src/shared"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
