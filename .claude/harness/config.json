{
  "version": "2.0.0",
  "name": "Moyan MFW Harness",
  "description": "墨焱管理后台基础框架 - 项目级自动化执行引擎",
  "enabled": true,

  "hooks": {
    "identity-greeting": {
      "enabled": true,
      "script": "hooks/identity-greeting-hook.ts",
      "timeout": 15000,
      "onFailure": "block",
      "message": "【身份报告检查失败】无法确定当前身份和开发模式。"
    },
    "session-start": {
      "enabled": true,
      "script": "hooks/session-start-hook.ts",
      "timeout": 30000,
      "onFailure": "block",
      "message": "【会话开始检查失败】请先完成任务确认再开始工作。"
    },
    "task-analysis": {
      "enabled": true,
      "script": "hooks/task-analysis-hook.ts",
      "timeout": 60000,
      "onFailure": "block",
      "message": "【任务分析检查失败】请先完成需求分析和边界确认。"
    },
    "meeting-required": {
      "enabled": true,
      "script": "hooks/meeting-required-hook.ts",
      "timeout": 60000,
      "onFailure": "block",
      "message": "【多 Agent 会议检查失败】复杂任务需要多 Agent 协作，请先组织协调会议。"
    },
    "pre-code": {
      "enabled": true,
      "script": "hooks/pre-code-hook.ts",
      "timeout": 30000,
      "onFailure": "block",
      "message": "【编码前检查失败】请先确认技术方案和边界条件。"
    },
    "code-quality-gate": {
      "enabled": true,
      "script": "hooks/code-quality-gate.ts",
      "timeout": 120000,
      "onFailure": "block",
      "message": "【代码质量检查失败】请修复问题后再提交。"
    },
    "session-end": {
      "enabled": true,
      "script": "hooks/session-end-hook.ts",
      "timeout": 60000,
      "onFailure": "remind",
      "message": "【会话结束检查失败】请先完成工作总结和任务更新。"
    }
  },

  "rules": {
    "task-file-path": ".claude/TASK.md",
    "memory-directory": ".harness/memory",
    "rules-directory": ".harness/rules",
    "output-directory": ".harness/output",
    "paths-config": ".claude/harness/config/paths.json",

    "required-sections-before-code": [
      "需求理解",
      "边界条件",
      "技术方案",
      "风险评估"
    ],

    "code-quality-checks": [
      "typecheck",
      "lint",
      "self-review"
    ]
  },

  "paths": {
    "$ref": "./config/paths.json"
  },

  "enforcement": {
    "strict-mode": true,
    "allowOverride": false,
    "logAllChecks": true,
    "identityReportRequired": true
  }
}
