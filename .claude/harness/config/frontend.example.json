{
  "$schema": "./frontend-config-schema.json",
  "description": "前端开发规范配置 - 请根据实际项目修改此文件",
  "framework": {
    "name": "React",
    "version": "18.x",
    "variants": ["Vue 3.x", "Angular 17.x"]
  },
  "styling": {
    "approach": "CSS Modules",
    "alternatives": ["Styled Components", "Tailwind CSS", "Sass"],
    "preprocessor": "Sass"
  },
  "buildTool": {
    "name": "Vite",
    "alternatives": ["Webpack", "Next.js"]
  },
  "componentNamingConventions": [
    {
      "pattern": "组件文件名",
      "rule": "PascalCase",
      "example": "UserProfile.tsx"
    },
    {
      "pattern": "组件函数名",
      "rule": "PascalCase",
      "example": "function UserProfile"
    },
    {
      "pattern": "辅助函数",
      "rule": "camelCase",
      "example": "formatUserName"
    },
    {
      "pattern": "常量",
      "rule": "UPPER_SNAKE_CASE",
      "example": "MAX_ITEMS"
    },
    {
      "pattern": "CSS 类名",
      "rule": "kebab-case (BEM)",
      "example": "user-profile__avatar"
    },
    {
      "pattern": "测试文件",
      "rule": "*.test.tsx 或 *.spec.tsx",
      "example": "UserProfile.test.tsx"
    }
  ],
  "responsiveBreakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "accessibility": {
    "standard": "WCAG 2.1 AA",
    "requirements": [
      "所有图片必须有 alt 属性",
      "表单控件必须有关联的 label",
      "颜色对比度至少 4.5:1 (文本), 3:1 (大文本)",
      "支持键盘导航（Tab 顺序合理）",
      "焦点状态必须可见",
      "使用语义化 HTML 标签 (header, nav, main, footer)",
      "ARIA 属性仅在必要时使用",
      "动态内容变化需通知屏幕阅读器"
    ]
  },
  "performanceOptimizations": [
    "实现组件懒加载 (React.lazy + Suspense)",
    "实现代码分割 (Code Splitting)",
    "图片使用 WebP 格式 + 懒加载",
    "使用 useMemo/useCallback 优化渲染",
    "虚拟滚动长列表",
    "防抖/节流高频事件",
    "预加载关键资源 (<link rel=\"preload\">)",
    "减少 bundle 大小 (Tree Shaking)"
  ]
}
