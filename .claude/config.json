{
  "version": "1.0.0",
  "project": "墨焱框架 (moyan-mfw)",
  "created": "2026-03-30",
  "updated": "2026-03-30",

  "rules": {
    "core": {
      "session-flow": {
        "enabled": true,
        "enforcement": "mandatory",
        "source": ".claude/rules/core/01-session-flow.md"
      },
      "task-management": {
        "enabled": true,
        "enforcement": "mandatory",
        "source": ".claude/rules/core/02-task-management.md"
      },
      "memory-rules": {
        "enabled": true,
        "enforcement": "mandatory",
        "source": ".claude/rules/core/03-memory-rules.md"
      }
    },
    "optional": {
      "_note": "规则文件建设中 - 临时使用统一开发规范代替"
    },
    "project-specific": {
      "naming-convention": {
        "enabled": true,
        "enforcement": "mandatory",
        "source": ".claude/rules/project-specific/naming-convention.md"
      },
      "component-spec": {
        "enabled": true,
        "enforcement": "mandatory",
        "source": ".claude/rules/project-specific/component-spec.md"
      }
    }
  },

  "paths": {
    "task-file": ".claude/TASK.md",
    "task-directory": "docs/04-项目实施/05-任务追踪",
    "memory-directory": ".claude/memory",
    "team-directory": ".claude/team",
    "meeting-directory": "docs/02-团队/04-会议纪要",
    "docs-root": "docs"
  },

  "enforcement": {
    "session-start-check": {
      "enabled": true,
      "action": "block",
      "message": "【会话开始检查未完成】请先读取 .claude/TASK.md 并确认任务状态，然后才能开始工作。"
    },
    "session-end-update": {
      "enabled": true,
      "action": "remind",
      "message": "【会话结束前请更新】请先更新 .claude/TASK.md 记录本次工作成果和下一步行动。"
    },
    "task-file-exists": {
      "enabled": true,
      "action": "block",
      "message": "【TASK.md 不存在】请先创建任务文件 .claude/TASK.md，记录当前任务状态。"
    },
    "constitution-check": {
      "enabled": true,
      "action": "remind",
      "message": "【请遵循项目宪法】请查阅 .claude.md 中定义的规则。"
    }
  },

  "team": {
    "mode": "virtual",
    "charter": "docs/02-团队/01-团队规范/01-团队章程.md",
    "roles": {
      "pm": { "name": "项目经理", "assigned": "claude", "description": "任务统一接收、分析、分派和协调" },
      "product": { "name": "产品经理", "assigned": null, "description": "需求分析、产品设计" },
      "ui": { "name": "UI 设计师", "assigned": null, "description": "界面设计、交互设计" },
      "tech-lead": { "name": "技术主管", "assigned": null, "description": "架构设计、技术方案评审" },
      "frontend": { "name": "前端工程师", "assigned": null, "description": "前端功能开发" },
      "backend": { "name": "后端工程师", "assigned": null, "description": "后端开发、API 设计" },
      "qa": { "name": "测试工程师", "assigned": null, "description": "测试计划与执行" },
      "audit": { "name": "项目审查", "assigned": null, "description": "文档与代码审查" },
      "doc": { "name": "文档维护专员", "assigned": null, "description": "会议纪要、文档管理" },
      "maintainer": { "name": "项目维护", "assigned": null, "description": "版本管理、发布配置" }
    },
    "task-assignment-pattern": "@角色 [任务描述]",
    "escalation": {
      "l1": { "level": "一般问题", "response": "24 小时", "handler": "对应角色" },
      "l2": { "level": "跨角色问题", "response": "12 小时", "handler": "项目经理" },
      "l3": { "level": "重大风险", "response": "4 小时", "handler": "项目经理 + 负责人" }
    }
  },

  "code-style": {
    "component-prefix": "Mfw",
    "directory-naming": "camel-case",
    "main-file-naming": "PascalCase",
    "sub-component-naming": "kebab-case",
    "composable-naming": "camel-case + use",
    "type-definition": "complete, no any",
    "file-header-required": true,
    "jsdoc-required": true,
    "tech-stack": {
      "base-components": "TSX + defineComponent",
      "business-components": "<script setup lang=\"ts\">",
      "vue": "3.4+",
      "typescript": "5.3+",
      "element-plus": "2.5+"
    }
  },

  "memory": {
    "auto-save-trigger": [
      "用户说'请记住'",
      "项目决策完成",
      "学习用户偏好",
      "发现工作模式"
    ],
    "save-location": ".claude/memory/",
    "index-file": ".claude/memory/MEMORY.md",
    "types": {
      "user": "用户角色、偏好、知识",
      "feedback": "用户给出的工作反馈",
      "project": "项目目标、决策、约束",
      "reference": "外部资源位置"
    }
  },

  "task": {
    "format": {
      "front-matter": ["task", "status", "priority", "started", "updated", "session"],
      "required-sections": ["当前目标", "已完成", "进行中", "待开始", "相关文件"],
      "optional-sections": ["关键决策", "备注"]
    },
    "status-values": ["pending", "in_progress", "blocked", "completed"],
    "priority-values": ["P0", "P1", "P2", "P3"],
    "lock-timeout": 300
  },

  "ai": {
    "providers": [
      {
        "name": "ppchat",
        "url": "https://code.ppchat.vip/v1",
        "key": "sk-agiOHdl90ncs4jbQRo9hi6pZiKf06KKgp9dEMy0ywbSRJutJ",
        "models": ["gpt-5.4"],
        "default": true
      }
    ]
  }
}
