{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(cd packages/* && pnpm *)",
      "Bash(git *)",
      "WebFetch",
      "Agent",
      "Edit(.claude/harness/**)",
      "Write(.claude/harness/**)",
      "Edit(.claude/memory/**)",
      "Write(.claude/memory/**)",
      "Edit(.claude/**/TASK*.md)",
      "Write(.claude/**/TASK*.md)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(packages/base-backend/src/**)",
      "Write(packages/base-backend/src/**)",
      "Edit(backend/src/**)",
      "Write(backend/src/**)",
      "Edit(packages/base-frontend/src/**)",
      "Write(packages/base-frontend/src/**)",
      "Edit(frontend/src/**)",
      "Write(frontend/src/**)",
      "Edit(examples/src/**)",
      "Write(examples/src/**)",
      "Edit(tests/**)",
      "Write(tests/**)",
      "Edit(test/**)",
      "Write(test/**)",
      "Edit(**/*.spec.ts)",
      "Write(**/*.spec.ts)",
      "Edit(**/*.test.ts)",
      "Write(**/*.test.ts)",
      "Edit(docs/**)",
      "Write(docs/**)",
      "Edit(**/*.md)",
      "Write(**/*.md)",
      "Edit(.harness/**)",
      "Write(.harness/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(del /f *)",
      "Bash(rmdir /s *)",
      "Bash(format *)",
      "Bash(mkfs *)",
      "Bash(dd *)"
    ],
    "additionalDirectories": [
      ".claude/harness",
      ".harness",
      ".harness/output",
      ".claude/memory",
      ".claude/agents"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:identity",
            "timeout": 30,
            "statusMessage": "🔔 运行 Harness 身份报告检查..."
          },
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:session-start",
            "timeout": 60,
            "statusMessage": "🔔 运行 Harness 会话开始检查..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:pre-code",
            "timeout": 60,
            "statusMessage": "🔔 运行 Harness 编码前检查..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:code-quality",
            "timeout": 180,
            "statusMessage": "🔔 运行 Harness 代码质量检查..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "project-manager",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:pm-context",
            "timeout": 30,
            "statusMessage": "📋 加载项目管理上下文..."
          }
        ]
      },
      {
        "matcher": "tech-architect",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:architect-context",
            "timeout": 30,
            "statusMessage": "🏗️ 加载架构设计上下文..."
          }
        ]
      },
      {
        "matcher": "backend-ts-node-dev",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:backend-security",
            "timeout": 30,
            "statusMessage": "🔒 注入后端安全规范..."
          }
        ]
      },
      {
        "matcher": "frontend-dev",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:frontend-guidelines",
            "timeout": 30,
            "statusMessage": "🎨 加载前端开发指南..."
          }
        ]
      },
      {
        "matcher": "code-reviewer-tester",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:review-checklist",
            "timeout": 30,
            "statusMessage": "📝 加载代码审查清单..."
          }
        ]
      },
      {
        "matcher": "docs-architect",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:docs-template",
            "timeout": 30,
            "statusMessage": "📄 加载文档模板..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "backend-ts-node-dev|frontend-dev|code-reviewer-tester|docs-architect",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:subagent-review",
            "timeout": 60,
            "statusMessage": "🔔 审查 subagent 工作成果..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd .harness && pnpm run hook:session-end",
            "timeout": 90,
            "statusMessage": "🔔 运行 Harness 会话结束检查..."
          }
        ]
      }
    ]
  }
}
