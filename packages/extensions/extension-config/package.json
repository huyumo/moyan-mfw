{
  "name": "moyan-mfw-extension-config",
  "version": "1.1.10-beta.10",
  "description": "MFW 配置管理扩展包",
  "exports": {
    "./backend": {
      "types": "./src/backend/dist/index.d.ts",
      "import": "./src/backend/dist/index.js",
      "require": "./src/backend/dist/index.js"
    },
    "./backend/*": {
      "types": "./src/backend/dist/*.d.ts",
      "import": "./src/backend/dist/*.js",
      "require": "./src/backend/dist/*"
    },
    "./frontend": {
      "types": "./src/frontend/dist/index.d.ts",
      "import": "./src/frontend/src/index.ts",
      "require": "./src/frontend/dist/index.mjs",
      "style": "./src/frontend/src/index.ts"
    },
    "./frontend/*": {
      "types": "./src/frontend/dist/*.d.ts",
      "import": "./src/frontend/src/*",
      "require": "./src/frontend/dist/*"
    },
    "./shared": {
      "types": "./src/shared/dist/index.d.ts",
      "import": "./src/shared/src/index.ts",
      "require": "./src/shared/dist/index.js"
    },
    "./shared/*": {
      "types": "./src/shared/dist/*.d.ts",
      "import": "./src/shared/src/*",
      "require": "./src/shared/dist/*"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./src/*/dist/*.d.ts",
        "./src/*/dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build:shared": "pnpm --filter @internal/config-shared build",
    "build:backend": "pnpm --filter moyan-mfw-base run build:shared && pnpm --filter moyan-mfw-base run build:backend && pnpm --filter @internal/config-backend build",
    "build:frontend": "pnpm --filter @internal/config-frontend build",
    "build": "pnpm run build:shared && pnpm run build:backend && pnpm run build:frontend",
    "dev:backend": "pnpm --filter @internal/config-backend dev",
    "dev:frontend": "pnpm --filter @internal/config-frontend dev",
    "typecheck:shared": "pnpm --filter @internal/config-shared typecheck",
    "typecheck:backend": "pnpm --filter @internal/config-backend typecheck",
    "typecheck:frontend": "pnpm --filter @internal/config-frontend typecheck",
    "typecheck": "pnpm run typecheck:shared && pnpm run typecheck:backend && pnpm run typecheck:frontend"
  },
  "license": "MIT",
  "keywords": [
    "moyan",
    "mfw",
    "extension",
    "config",
    "配置管理"
  ],
  "files": [
    "src/backend/dist",
    "src/frontend/dist",
    "src/shared/dist",
    "database/migrations",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
