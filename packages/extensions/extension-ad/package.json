{
  "name": "moyan-mfw-extension-ad",
  "version": "0.1.0",
  "description": "MFW 广告管理扩展包",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./backend": {
      "types": "./src/backend/index.ts",
      "require": "./dist/backend/index.js",
      "default": "./src/backend/index.ts"
    },
    "./frontend": {
      "types": "./src/frontend/index.ts",
      "require": "./dist/frontend/index.js",
      "default": "./src/frontend/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "require": "./dist/shared/index.js",
      "default": "./src/shared/index.ts"
    }
  },
  "typesVersions": {
    "*": {
      "backend": ["./src/backend/index.ts"],
      "frontend": ["./src/frontend/index.ts"],
      "shared": ["./src/shared/index.ts"]
    }
  },
  "scripts": {
    "dev:backend": "nest start --watch",
    "dev:frontend": "vite",
    "api:build": "node api.build.cjs",
    "build:routes": "node scripts/build-routes.mjs",
    "build": "tsc",
    "prepublishOnly": "pnpm api:build && pnpm build:routes && pnpm build"
  },
  "files": [
    "dist",
    "migrations",
    "api.build.cjs",
    "scripts",
    "extension.json",
    "src/frontend/routes.gen.ts"
  ],
  "peerDependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/typeorm": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "moyan-mfw-base": "workspace:^",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "typeorm": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:",
    "@element-plus/icons-vue": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "element-plus": "catalog:",
    "moyan-api": "catalog:",
    "moyan-mfw-base": "workspace:*",
    "sass": "catalog:",
    "tsx": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  }
}