{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "typeorm": ["./node_modules/typeorm"],
      "moyan-base/backend": ["../../base/dist/backend"],
      "moyan-base/frontend": ["../../base/src/frontend/index.ts"],
      "moyan-base/shared": ["../../base/src/shared/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/frontend"]
}
