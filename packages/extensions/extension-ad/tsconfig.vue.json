{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "emitDecoratorMetadata": false,
    "paths": {
      "typeorm": ["./node_modules/typeorm"],
      "@/*": ["./src/frontend/*"]
    }
  },
  "include": ["src/frontend/**/*.ts", "src/frontend/**/*.vue"],
  "exclude": ["src/backend"]
}
