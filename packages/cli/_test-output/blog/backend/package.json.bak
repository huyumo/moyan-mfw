{
  "name": "@internal/blog-backend",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "moyan-mfw-base/backend": "workspace:",
    "@internal/blog-shared": "workspace:*"
  },
  "devDependencies": { "typescript": "catalog:", "tsup": "catalog:", "tsx": "catalog:" }
}
