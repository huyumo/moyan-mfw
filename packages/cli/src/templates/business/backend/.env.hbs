# 数据库配置
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME={{snakeCase name}}

# 缓存驱动：none（不开启）| auto（自动降级）| redis（强制 Redis）| memory（强制内存）
CACHE_DRIVER=none

# JWT 配置
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# 服务端口
PORT={{port}}

# 运行环境
NODE_ENV=development

# OSS 配置（阿里云 STS 临时凭证，可选）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ROLE_ARN=
OSS_TOKEN_EXPIRE_TIME=3600
OSS_BUCKET=
OSS_ENDPOINT=
OSS_TIMEOUT=60
