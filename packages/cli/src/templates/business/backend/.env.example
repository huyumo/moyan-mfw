# 环境变量配置
# 复制此文件为 .env 并填写实际配置

# ==================== 应用配置 ====================
NODE_ENV=development
PORT=3000
APP_NAME=MyApp Backend

# ==================== 数据库配置 ====================
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=my_db

# ==================== Redis 配置 ====================
# 缓存驱动：none（不开启）| auto（自动降级）| redis（强制 Redis）| memory（强制内存）
CACHE_DRIVER=none
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=mfw:
REDIS_DEFAULT_TTL=1800

# ==================== JWT 配置 ====================
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# ==================== CORS 配置 ====================
CORS_ORIGIN=*

# ==================== 日志配置 ====================
LOG_LEVEL=debug
SQL_LOGGING=true

# ==================== 用户配置 ====================
ADMIN_DEFAULT_PASSWORD_TYPE=fixed
ADMIN_DEFAULT_PASSWORD=Admin@123

# ==================== 上传配置 ====================
UPLOAD_DIR=uploads
