{
  "name": "{{name}}",
  "version": "0.1.0",
  "private": true,
  "description": "{{description}}",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm run -r build",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ]
  }
}
