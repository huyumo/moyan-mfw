{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist/backend",
    "rootDir": "./src/backend",
    "declaration": true,
    "declarationMap": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/backend/*"],
      "@common/*": ["src/backend/common/*"],
      "@modules/*": ["src/backend/modules/*"],
      "@config/*": ["src/backend/config/*"],
      "@database/*": ["src/backend/database/*"]
    }
  },
  "include": ["src/backend/**/*"],
  "exclude": ["node_modules", "dist"]
}
