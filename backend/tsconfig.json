{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "strictPropertyInitialization": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "moyan-mfw-base/backend": ["../packages/base/src/backend/dist"],
      "moyan-mfw-base/backend/*": ["../packages/base/src/backend/dist/*"],
      "moyan-mfw-base/shared": ["../packages/base/src/shared/dist"],
      "moyan-mfw-base/shared/*": ["../packages/base/src/shared/dist/*"],
      "moyan-mfw-extension-ad/backend": ["../packages/extensions/extension-ad/src/backend/dist"],
      "moyan-mfw-extension-ad/backend/*": ["../packages/extensions/extension-ad/src/backend/dist/*"],
      "moyan-mfw-extension-ad/shared": ["../packages/extensions/extension-ad/src/shared/dist"],
      "moyan-mfw-extension-ad/shared/*": ["../packages/extensions/extension-ad/src/shared/dist/*"],
      "moyan-mfw-extension-config/backend": ["../packages/extensions/extension-config/src/backend/dist"],
      "moyan-mfw-extension-config/backend/*": ["../packages/extensions/extension-config/src/backend/dist/*"],
      "moyan-mfw-extension-config/shared": ["../packages/extensions/extension-config/src/shared/dist"],
      "moyan-mfw-extension-config/shared/*": ["../packages/extensions/extension-config/src/shared/dist/*"],
      "moyan-mfw-business-dict": ["../business-dict/dist/esm"],
      "moyan-mfw-business-dict/*": ["../business-dict/dist/esm/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
