{
  "name": "moyan-backend",
  "version": "1.0.0",
  "description": "Moyan 后台管理 - 业务后端应用",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --config jest.config.ts --coverage",
    "typeorm": "ts-node -r tsconfig-paths/register --project ../tsconfig.json ../node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d src/database/data-source.ts",
    "migration:run": "pnpm typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/database/data-source.ts",
    "migration:show": "pnpm typeorm migration:show -d src/database/data-source.ts",
    "seed:run": "ts-node -r tsconfig-paths/register src/database/run-seeds.ts",
    "db:clear": "ts-node -r tsconfig-paths/register src/database/clear-database.ts",
    "api:build": "node api.build.cjs"
  },
  "dependencies": {
    "moyan-base": "workspace:*",
    "moyan-extension-ad": "workspace:*",
    "moyan-shared-dict": "workspace:*",
    "business-dict": "workspace:*",
    "dotenv": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/jwt": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/typeorm": "catalog:",
    "bcrypt": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "mysql2": "catalog:",
    "redis": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "typeorm": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/bcrypt": "catalog:",
    "@types/express": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "source-map-support": "catalog:",
    "supertest": "catalog:",
    "ts-jest": "catalog:",
    "ts-loader": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
