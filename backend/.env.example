# 环境变量配置示例
# 复制此文件为 .env 并填写实际配置

# ==================== 应用配置 ====================
# 应用环境：development | production | test
NODE_ENV=development

# 应用端口
PORT=3000

# 应用名称
APP_NAME=Moyan MFW Backend

# 应用版本
APP_VERSION=1.0.0

# API 前缀
API_PREFIX=/api

# ==================== 数据库配置 ====================
# 数据库主机
DB_HOST=localhost

# 数据库端口
DB_PORT=3306

# 数据库用户名
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=

# 数据库名称
DB_NAME=moyan_mfw

# 连接池大小
DB_POOL_SIZE=100

# ==================== Redis 配置 ====================
# Redis 主机
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码
REDIS_PASSWORD=

# Redis 数据库
REDIS_DB=0

# Redis 键前缀
REDIS_KEY_PREFIX=mfw:

# Redis 默认 TTL（秒）
REDIS_DEFAULT_TTL=1800

# ==================== JWT 配置 ====================
# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=default-secret-change-in-production

# JWT 过期时间（秒）
JWT_EXPIRES_IN=86400

# JWT 刷新 Token 过期时间（秒）
JWT_REFRESH_EXPIRES_IN=604800

# ==================== CORS 配置 ====================
# 允许的源（多个用逗号分隔）
CORS_ORIGIN=*

# ==================== 日志配置 ====================
# 日志级别：error | warn | log | http | verbose | debug | silly
LOG_LEVEL=debug

# 是否记录 SQL 日志
SQL_LOGGING=true

# ==================== 用户配置 ====================
# 管理员创建用户时的默认密码策略：fixed（固定密码）| phone（手机号后8位）
ADMIN_DEFAULT_PASSWORD_TYPE=fixed

# 固定密码值（仅当 ADMIN_DEFAULT_PASSWORD_TYPE=fixed 时生效）
ADMIN_DEFAULT_PASSWORD=Admin@123

# ==================== 上传配置 ====================
# 上传目录
UPLOAD_DIR=uploads